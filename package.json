{
  "name": "comfy-node-designer",
  "version": "1.0.0",
  "description": "A modern GUI for designing and generating ComfyUI custom nodes",
  "main": "./out/main/index.js",
  "author": "MNeMoNiCuZ",
  "license": "MIT",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq-sdk": "^0.9.1",
    "lucide-react": "^0.475.0",
    "monaco-editor": "^0.52.2",
    "openai": "^4.85.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.20.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.1.5",
    "vitest": "^3.0.6"
  },
  "build": {
    "appId": "com.mnemonicuz.comfynodedesigner",
    "productName": "Comfy Node Designer",
    "icon": "src/assets/ComfyUINodeDesigner.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "src/assets/ComfyUINodeDesigner.png", "to": "icon.png" }
    ],
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/ComfyUINodeDesigner.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/ComfyUINodeDesigner.png"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/ComfyUINodeDesigner.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
